# ── Azure OpenAI ────────────────────────────────────────────────────────────────────
AZURE_OPENAI_API_KEY=REPLACE_WITH_YOUR_API_KEY
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_BASE_URL=

AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-5
AZURE_OPENAI_REASONING_DEPLOYMENT=gpt-5-mini
AZURE_OPENAI_EXTRACTION_DEPLOYMENT=gpt-5-mini
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-large

# ── Runtime ────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
OUTPUT_DIR=outputs

# ── PROMISE ───────────────────────────────────────────────────────────────────
PROMISE_INPUT=data/promise/promise.csv
PROMISE_HAS_HEADER=true
PROMISE_PROJECT_COL=ProjectID
PROMISE_TEXT_COL=RequirementText
PROMISE_LABEL_COL=class
PROMISE_MAX_PROJECTS=15
PROMISE_MAX_REQS_PER_PROJECT=100

# ── PURE ──────────────────────────────────────────────────────────────────────
PURE_INPUT_DIR=data/pure
PURE_MAX_DOCS=10

PURE_RAW_CHUNK_CHARS=12000
PURE_RAW_CHUNK_OVERLAP=1200

PURE_PROFILE_SUMMARY_CHARS=50000

PURE_MAX_SECTION_CHUNKS=60
PURE_MAX_RAW_CHUNKS=50

PURE_REQ_SIGNAL_MIN=2

# ── Generation ────────────────────────────────────────────────────────────────
ARTIFACT_COUNT=3
MAX_REPAIR_ROUNDS=1
MIN_COVERAGE_RATE=0.90
MAX_UNSUPPORTED_COUNT=2
TEMP_GENERATION=0.4
TEMP_VALIDATION=0.0

MAX_TOKENS_GENERATION=16000   
MAX_TOKENS_VALIDATION=4096    
MAX_TOKENS_EXTRACTION=4096   
MAX_TOKENS_MERGE=8192         
